# --- Required ---------------------------------------------------------------
# Your gateway API "security key".
# EPD / NMI merchant portal -> Settings -> Security Keys.
# A READ-ONLY key is sufficient and strongly recommended for this server.
NMI_SECURITY_KEY=

# --- Optional ---------------------------------------------------------------
# Gateway API base URL. Defaults to NMI's shared endpoint.
# NMI white-label gateways expose the same API on their own host
# (typically secure.<brand>.com). Confirm your exact host in the merchant
# portal / your integration docs before changing this.
#
#   NMI (default):    https://secure.nmi.com
#   Easy Pay Direct:  set to the gateway host shown in your EPD portal
#
# NMI_API_URL=https://secure.nmi.com
